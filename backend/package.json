{
  "name": "soulconnect-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "echo 'Production build'",
    "start": "node src/server.js",
    "db:migrate": "node --loader dotenv/config scripts/migrate.js",
    "db:seed": "node --loader dotenv/config scripts/seed.js",
